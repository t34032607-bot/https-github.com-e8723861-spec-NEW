.env.example
# Hybrid DCA Grid Bot Configuration

# API Credentials (from your exchange)
# IMPORTANT: Never commit .env with real credentials to version control
CRYPTO_API_KEY=r_api_key_here
CRYPTO_API_SECRET=pmiyour_api_secret_here

# Trading Mode
# Set to 'true' for paper trading (safe testing)
# Set to 'false' for live trading (real money - use with caution!)
PAPER_TRADING=false


# Trading Symbol
TRADING_SYMBOL=BTC-USD

# Optional: Path to settings file
# SETTINGS_FILE=gui_settings.json
