    symbol = os.getenv("BOT_SYMBOL", "BTC-USD")
    run_mode = os.getenv("RUN_MODE", "development")
    
    print()
    print("╔═══════════════════════════════════════════════════╗")
    print("║  Hybrid DCA Grid Trading Bot - Starting           ║")
    print(f"║  Mode: {'PAPER TRADING (Safe)' if paper_trading else 'LIVE TRADING (Real Money)'}")
    print(f"║  Symbol: {symbol}")
    print(f"║  Environment: {run_mode.upper()}")
    print("╚═══════════════════════════════════════════════════╝")
    print()
    
    api = CryptoAPITrading(paper_trading=paper_trading)
    bot = HybridDCAInfinityGrid(api, symbol)

    try:
        bot.start()
        while True:
            time.sleep(60)
    except KeyboardInterrupt:
        logger.info("⏸ Received interrupt signal - shutting down gracefully...")
        bot.stop()
        logger.info("✅ Bot stopped cleanly")
    except Exception as e:
        logger.critical(f"Fatal error: {e}")
        if bot.notifications:
            try:
                bot.notifications.send_error_alert(f"Bot crashed: {str(e)}")
            except Exception as send_err:
                logger.warning(f"Failed to send crash alert: {send_err}")
        bot.stop()
        raise