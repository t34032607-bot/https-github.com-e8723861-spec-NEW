        self._place_grid_orders(current_price)
        self._save_state()

        self.monitor_thread = threading.Thread(target=self._light_monitor_loop, daemon=True)
        self.monitor_thread.start()

    def _start_user_data_stream(self):
        """Modern WebSocket API approach for user data (post-listenKey deprecation)"""
        try:
            # For Spot: Use WebSocket API session with authentication
            # Note: For real Binance, you need to get a listenKey first via REST API
            ws_base = "wss://stream.binance.com:9443" if not getattr(self.api, "api_type", "spot") == "futures" else "wss://fstream.binance.com"
            ws_url = f"{ws_base}/ws"   # You may need to adjust to the new WebSocket API endpoint if required by your setup

            logger.info(f"🔗 Connecting to WebSocket: {ws_url}")
            self.user_ws = websocket.WebSocketApp(
                ws_url,
                on_message=self._on_user_ws_message,
                on_error=self._on_user_ws_error,
                on_close=self._on_user_ws_close,
                on_open=self._on_user_ws_open
            )

            ws_thread = threading.Thread(target=self.user_ws.run_forever, daemon=True, kwargs={"ping_interval": 30})
            ws_thread.start()
            logger.info("User Data Stream WebSocket thread started (real-time fills enabled)")

        except Exception as e:
            logger.error(f"Failed to start User Data Stream: {e}")

