logger = logging.getLogger("HybridDCAInfinityGrid")

class HybridDCAInfinityGrid:
    def __init__(self, api: CryptoAPITrading, symbol: str = "BTC-USD"):
        self.api = api
        self.symbol = symbol
        self.base = symbol.split("-")[0].upper()
        self.binance_symbol = self.base + "USDT"

        self.state_file = f"hybrid_state_{self.base}.json"
        self.settings = self._load_settings()

        # State
        self.target_usd_exposure: float = 0.0
        self.peak_exposure: float = 0.0
        self.lower_price_floor: float = 0.0
        self.active_orders: Dict[str, dict] = {}
        self.dca_stages_triggered: list = []
        self.last_rebalance_ts: float = 0.0
        self.daily_trades: int = 0
        self.daily_reset_ts: float = time.time()

        self.running = False
        self.monitor_thread = None
        self.user_ws = None
        self.symbol_info = self._fetch_symbol_info()

        self._load_state()

    def _fetch_symbol_info(self) -> dict:
        try:
            resp = self.api.make_api_request("GET", f"/api/v3/exchangeInfo?symbol={self.binance_symbol}")
            if resp and "symbols" in resp:
                for s in resp["symbols"]:
                    if s["symbol"] == self.binance_symbol:
                        filters = {f["filterType"]: f for f in s.get("filters", [])}
                        return {
                            "stepSize": float(filters.get("LOT_SIZE", {}).get("stepSize", 0.000001)),
                            "tickSize": float(filters.get("PRICE_FILTER", {}).get("tickSize", 0.01)),
                        }
        except Exception as e:
            logger.warning(f"Symbol info failed: {e}")
        return {"stepSize": 0.000001, "tickSize": 0.01}

    def _round_qty(self, qty: float) -> float:
        step = self.symbol_info["stepSize"]
        return math.floor(qty / step) * step

    def _round_price(self, price: float) -> float:
        tick = self.symbol_info["tickSize"]
        return round(price / tick) * tick

    def _load_settings(self) -> dict:
        base = _load_gui_settings()
        return {
            "enabled": True,
            "min_signal_level": base.get("trade_start_level", TRADE_START_LEVEL),
            "target_usd_pct": 0.08,                    # Conservative for small capital
            "base_grid_spacing_pct": 0.9,
            "num_grids": 10,
            "profit_release_threshold_pct": 4.0,
            "profit_release_pct": 0.30,
            "max_drawdown_pct": 20.0,
            "lower_floor_pct": 0.78,
            "max_daily_trades": 15,
            "start_allocation_pct": base.get("start_allocation_pct", START_ALLOC_PCT),
            "dca_multiplier": base.get("dca_multiplier", DCA_MULTIPLIER),
            "dca_levels": base.get("dca_levels", DCA_LEVELS),
            "max_dca_buys_per_24h": base.get("max_dca_buys_per_24h", MAX_DCA_BUYS_PER_24H),
        }

    def _load_state(self):
        if os.path.isfile(self.state_file):
            try:
                with open(self.state_file, "r") as f:
                    data = json.load(f)
                self.target_usd_exposure = data.get("target_usd_exposure", 0.0)
                self.lower_price_floor = data.get("lower_price_floor", 0.0)
                self.dca_stages_triggered = data.get("dca_stages_triggered", [])
                logger.info(f"Loaded saved state for {self.symbol}")
            except Exception as e:
                logger.warning(f"State load failed: {e}")

    def _save_state(self):
        try:
            data = {
                "target_usd_exposure": self.target_usd_exposure,
                "lower_price_floor": self.lower_price_floor,
                "dca_stages_triggered": self.dca_stages_triggered,
                "last_updated": time.time()
            }
            with open(self.state_file, "w") as f:
                json.dump(data, f, indent=2)
        except Exception as e:
            logger.error(f"State save failed: {e}")

    def start(self):
        if self.running: return
        self.running = True
        logger.info(f"🚀 Starting Hybrid DCA + Infinity Grid (User Data Stream) on {self.symbol}")

        # Start real-time User Data Stream
        self._start_user_data_stream()

        # Initial setup
        buy_p, sell_p, _ = self.api.get_price([self.symbol])
        current_price = buy_p.get(self.symbol) or sell_p.get(self.symbol) or 0
        if not current_price:
            logger.error("No price available")
            return

        acct = self.api.get_account()
        buying_power = float(acct.get("buying_power", 0)) if isinstance(acct, dict) else 0
        self.target_usd_exposure = buying_power * self.settings["target_usd_pct"]
        self.peak_exposure = self.target_usd_exposure
        self.lower_price_floor = current_price * self.settings["lower_floor_pct"]

        # Initial buy using your PowerTrader allocation
        initial_usd = self.target_usd_exposure * self.settings["start_allocation_pct"]
        qty = self._round_qty(initial_usd / current_price)
        if qty > 0:
            self._place_limit_order("BUY", current_price, qty, tag="INITIAL")

        self._place_grid_orders(current_price)
        self._save_state()

        self.monitor_thread = threading.Thread(target=self._light_monitor_loop, daemon=True)
        self.monitor_thread.start()

    def _start_user_data_stream(self):
        """Modern WebSocket API approach for user data (post-listenKey deprecation)"""
        try:
            # For Spot: Use WebSocket API session with authentication
            # Fallback / simplified for compatibility with your existing make_api_request
            ws_base = "wss://stream.binance.com:9443" if not getattr(self.api, "api_type", "spot") == "futures" else "wss://fstream.binance.com"
            ws_url = f"{ws_base}/ws"   # You may need to adjust to the new WebSocket API endpoint if required by your setup

            self.user_ws = websocket.WebSocketApp(
                ws_url,
                on_message=self._on_user_ws_message,
                on_error=self._on_user_ws_error,
                on_close=self._on_user_ws_close,
                on_open=self._on_user_ws_open
            )

            threading.Thread(target=self.user_ws.run_forever, daemon=True, kwargs={"ping_interval": 30}).start()
            logger.info("User Data Stream WebSocket started (real-time fills)")

        except Exception as e:
            logger.error(f"Failed to start User Data Stream: {e}")

    def _on_user_ws_open(self, ws):
        logger.info("✅ User Data WebSocket connected - instant fill detection active")

    def _on_user_ws_message(self, ws, message: str):
        try:
            data = json.loads(message)
            if data.get("e") == "executionReport":
                self._handle_execution_report(data)
        except Exception as e:
            pass  # Silently ignore malformed messages

    def _on_user_ws_error(self, ws, error):
        logger.warning(f"User WS error: {error}")

    def _on_user_ws_close(self, ws, close_status, close_msg):
        logger.warning("User Data WebSocket closed")

    def _handle_execution_report(self, report: dict):
        """Instant fill handling"""
        order_id = str(report.get("i") or report.get("orderId", ""))
        status = report.get("X", "")
        side = report.get("S", "").lower()
        executed_qty = float(report.get("z", 0))
        price = float(report.get("L", 0)) or float(report.get("p", 0))

        if status in ("FILLED", "PARTIALLY_FILLED") and executed_qty > 0:
            tag = self.active_orders.get(order_id, {}).get("tag", "GRID")
            logger.info(f"Instant fill: {side.upper()} {executed_qty:.6f} @ {price:.4f} | Tag: {tag}")

            # Record using your original ledger
            try:
                self.api._record_trade(
                    side=side,
                    symbol=self.symbol,
                    qty=executed_qty,
                    price=price,
                    tag=tag,
                    order_id=order_id
                )
            except Exception:
                pass

            # Update DCA tracking
            if side == "buy" and "DCA" in tag.upper():
                for level in self.settings["dca_levels"]:
                    if level not in self.dca_stages_triggered:
                        self.dca_stages_triggered.append(level)
                        break

            # Immediate rebalance after fill
            self._rebalance_after_fill()

            self.active_orders.pop(order_id, None)

    def _rebalance_after_fill(self):
        buy_p, sell_p, _ = self.api.get_price([self.symbol])
        current_price = buy_p.get(self.symbol) or sell_p.get(self.symbol) or 0
        if current_price > 0:
            self._place_grid_orders(current_price)
            self._save_state()

    def _place_limit_order(self, side: str, price: float, qty: float, tag: str = "GRID") -> Optional[str]:
        price = self._round_price(price)
        qty = self._round_qty(qty)
        if qty <= 0: return None

        params = {
            "symbol": self.binance_symbol,
            "side": side.upper(),
            "type": "LIMIT",
            "timeInForce": "GTC",
            "quantity": str(qty),
            "price": str(price),
        }

        try:
            resp = self.api.make_api_request("POST", "/api/v3/order", json.dumps(params))
            if resp and "orderId" in resp:
                order_id = str(resp["orderId"])
                self.active_orders[order_id] = {"side": side.lower(), "price": price, "qty": qty, "ts": time.time(), "tag": tag}
                logger.info(f"[{tag}] {side} limit @ {price} | Qty: {qty}")
                self.daily_trades += 1
                return order_id
        except Exception as e:
            logger.error(f"Order failed: {e}")
        return None

    def _place_grid_orders(self, current_price: float):
        self._cancel_all_orders()
        spacing = self.settings["base_grid_spacing_pct"]
        step = current_price * (spacing / 100.0)

        for i in range(1, self.settings["num_grids"] + 1):
            buy_price = self._round_price(current_price - i * step)
            sell_price = self._round_price(current_price + i * step)

            if buy_price > self.lower_price_floor:
                qty_buy = self._round_qty((self.target_usd_exposure / self.settings["num_grids"]) / buy_price)
                self._place_limit_order("BUY", buy_price, qty_buy, tag="GRID_BUY")

            qty_sell = self._round_qty((self.target_usd_exposure / self.settings["num_grids"]) / sell_price)
            self._place_limit_order("SELL", sell_price, qty_sell, tag="GRID_SELL")

    def _cancel_all_orders(self):
        for oid in list(self.active_orders.keys()):
            try:
                self.api.make_api_request("DELETE", f"/api/v3/order?symbol={self.binance_symbol}&orderId={oid}")
            except Exception:
                pass
        self.active_orders.clear()

    def _light_monitor_loop(self):
        while self.running:
            try:
                now = time.time()
                if now - self.daily_reset_ts > 86400:
                    self.daily_trades = 0
                    self.daily_reset_ts = now

                signal = self.api._read_long_dca_signal(self.base)
                if signal < self.settings["min_signal_level"]:
                    time.sleep(60)
                    continue

                self._handle_dca()   # DCA check (signal-driven)
                self._check_profit_release()
                if self._check_drawdown() > self.settings["max_drawdown_pct"]:
                    logger.warning("Max drawdown reached - stopping")
                    self.stop()

                time.sleep(30)
            except Exception as e:
                logger.error(f"Monitor error: {e}")
                time.sleep(30)

    def _handle_dca(self):
        # Your original staged DCA logic (simplified)
        if self.daily_trades >= self.settings["max_dca_buys_per_24h"]:
            return
        # Fetch current price
        buy_p, sell_p, _ = self.api.get_price([self.symbol])
        current_price = buy_p.get(self.symbol) or sell_p.get(self.symbol) or 0
        if current_price <= 0:
            return
        # Compute unrealized % from your cost_basis or holdings
        # For now placeholder - replace with real calculation
        unrealized_pct = -3.0
        for level in self.settings["dca_levels"]:
            if unrealized_pct <= level and level not in self.dca_stages_triggered:
                dca_usd = self.target_usd_exposure * (self.settings["dca_multiplier"] ** len(self.dca_stages_triggered))
                qty = self._round_qty(dca_usd /  current_price)  # use latest price
                if qty > 0:
                    self._place_limit_order("BUY", current_price, qty, tag=f"DCA_{level}")
                    self.dca_stages_triggered.append(level)
                break

    def _rebalance(self, current_price: float):
        # Grid rebalance to maintain target exposure
        # (implement similar to previous versions)
        pass  # reuse logic from earlier

    def _check_profit_release(self):
        # Your trailing PM style release
        # placeholder - compute unrealized %
        pass

    def _check_drawdown(self) -> float:
        return 0.0  # placeholder

    def stop(self):
        self.running = False
        if self.user_ws:
            self.user_ws.close()
        self._cancel_all_orders()
        self._save_state()
        logger.info("🛑 Hybrid Bot stopped")

