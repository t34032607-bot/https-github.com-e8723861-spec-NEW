    def _handle_execution_report(self, report: dict):
        """Instant fill handling with WebSocket integration"""
        order_id = str(report.get("i") or report.get("orderId", ""))
        status = report.get("X", "")
        side = report.get("S", "").lower()
        executed_qty = float(report.get("z", 0))
        price = float(report.get("L", 0)) or float(report.get("p", 0))

        if status in ("FILLED", "PARTIALLY_FILLED") and executed_qty > 0:
            tag = self.active_orders.get(order_id, {}).get("tag", "GRID")
            logger.info(f"⚡ INSTANT FILL: {side.upper()} {executed_qty:.8f} @ ${price:.2f} | Tag: {tag} | OrderID: {order_id}")

            # Record using your original ledger
            try:
                _record_trade(
                    side=side,
                    symbol=self.symbol,
                    qty=executed_qty,
                    price=price,
                    tag=tag,
                    order_id=order_id
                )
            except Exception as e:
                logger.error(f"Trade recording error: {e}")

            # Send trade alert
            if self.notifications:
                trade_data = {
                    "side": side,
                    "symbol": self.symbol,
                    "qty": executed_qty,
                    "price": price,
                    "tag": tag,
                    "order_id": order_id
                }
                try:
                    self.notifications.send_trade_alert(trade_data)
                except Exception as e:
                    logger.warning(f"Failed to send trade alert: {e}")

            # Update health monitor
            if self.health_monitor:
                self.health_monitor.increment_metric("trades_executed")

            # Update DCA tracking
            if side == "buy" and "DCA" in tag.upper():
                for level in self.settings["dca_levels"]:
                    if level not in self.dca_stages_triggered:
                        self.dca_stages_triggered.append(level)
                        logger.info(f"🚀 DCA Level {level}% triggered")
                        
                        # Send DCA alert
                        if self.notifications:
                            try:
                                self.notifications.send_dca_alert(level, self.symbol)
                            except Exception as e:
                                logger.warning(f"Failed to send DCA alert: {e}")
                        break

            # Immediate rebalance after fill (FAST REACTION)
            logger.info(f"🔄 Rebalancing grid after fill...")
            self._rebalance_after_fill()

            self.active_orders.pop(order_id, None)

    def _rebalance_after_fill(self):
        buy_p, sell_p, _ = self.api.get_price([self.symbol])
        current_price = buy_p.get(self.symbol) or sell_p.get(self.symbol) or 0
        if current_price > 0:
            self._place_grid_orders(current_price)
            self._save_state()

    def _place_limit_order(self, side: str, price: float, qty: float, tag: str = "GRID") -> Optional[str]:
        price = self._round_price(price)
        qty = self._round_qty(qty)
        if qty <= 0: return None
        
        # Check notional value (Binance requires minimum notional per order)
        notional = qty * price
        MIN_NOTIONAL = 10.0  # Minimum $10 notional for most pairs
        if notional < MIN_NOTIONAL:
            logger.debug(f"Order {tag} skipped - notional ${notional:.2f} below minimum ${MIN_NOTIONAL}")
            return None

        params = {
            "symbol": self.binance_symbol,
            "side": side.upper(),
            "type": "LIMIT",
            "timeInForce": "GTC",
            "quantity": self._format_decimal(qty, is_price=False),
            "price": self._format_decimal(price, is_price=True),
        }

        try:
            resp = self.api.make_api_request("POST", "/api/v3/order", json.dumps(params))
            if resp and "orderId" in resp:
                order_id = str(resp["orderId"])
                self.active_orders[order_id] = {"side": side.lower(), "price": price, "qty": qty, "ts": time.time(), "tag": tag}
                logger.info(f"[{tag}] {side} limit @ {price} | Qty: {qty}")
                self.daily_trades += 1
                return order_id
        except Exception as e:
            logger.error(f"Order failed: {e}")
        return None

    def _place_grid_orders(self, current_price: float):
        """Place grid orders in parallel for faster execution"""
        self._cancel_all_orders()
        spacing = self.settings["base_grid_spacing_pct"]
        step = current_price * (spacing / 100.0)

        # Prepare all orders to place
        orders_to_place = []
        for i in range(1, self.settings["num_grids"] + 1):
            buy_price = self._round_price(current_price - i * step)
            sell_price = self._round_price(current_price + i * step)

            if buy_price > self.lower_price_floor:
                qty_buy = self._round_qty((self.target_usd_exposure / self.settings["num_grids"]) / buy_price)
                orders_to_place.append(("BUY", buy_price, qty_buy, "GRID_BUY"))

            qty_sell = self._round_qty((self.target_usd_exposure / self.settings["num_grids"]) / sell_price)
            orders_to_place.append(("SELL", sell_price, qty_sell, "GRID_SELL"))

        # Place all orders in parallel using ThreadPoolExecutor
        logger.info(f"📈 Placing {len(orders_to_place)} grid orders in parallel...")
        start_time = time.time()
        
        with ThreadPoolExecutor(max_workers=16) as executor:
            futures = [executor.submit(self._place_limit_order, side, price, qty, tag) 
                      for side, price, qty, tag in orders_to_place]
            # Wait for all to complete
            for future in futures:
                future.result()
        
        elapsed = time.time() - start_time
        logger.info(f"Grid placed in {elapsed:.3f}s ({len(orders_to_place)/elapsed:.1f} orders/sec)")

    def _cancel_all_orders(self):
        for oid in list(self.active_orders.keys()):
            try:
                self.api.make_api_request("DELETE", f"/api/v3/order?symbol={self.binance_symbol}&orderId={oid}")
            except Exception:
                pass
        self.active_orders.clear()

    def _light_monitor_loop(self):
        last_health_check = time.time()
        health_check_interval = int(os.getenv("HEALTH_CHECK_INTERVAL", 300))
        
        while self.running:
            try:
                now = time.time()
                if now - self.daily_reset_ts > 86400:
                    self.daily_trades = 0
                    self.daily_reset_ts = now

                # Periodic health check
                if now - last_health_check > health_check_interval:
                    if self.health_monitor:
                        self.health_monitor.check_health()
                        try:
                            self.health_monitor.save_health_report()
                        except Exception as e:
                            logger.warning(f"Failed to save health report: {e}")
                    last_health_check = now

                signal = _read_long_dca_signal(self.base)
                if signal < self.settings["min_signal_level"]:
                    # No signal - check less frequently
                    time.sleep(random.uniform(3, 5))
                    continue

                # Signal present - check frequently for opportunities
                self._handle_dca()   # DCA check (signal-driven)
                self._check_profit_release()
                if self._check_drawdown() > self.settings["max_drawdown_pct"]:
                    logger.warning("Max drawdown reached - stopping")
                    if self.notifications:
                        try:
                            self.notifications.send_error_alert("Max drawdown reached")
                        except Exception as e:
                            logger.warning(f"Failed to send alert: {e}")
                    self.stop()

                # Ultra-fast monitoring loop - check every 1-2 seconds (SPEED MODE)
                time.sleep(random.uniform(1, 2))
            except Exception as e:
                logger.error(f"Monitor error: {e}")
                if self.health_monitor:
                    self.health_monitor.increment_metric("errors_count")
                time.sleep(random.uniform(2, 5))

